# .gitignore

# ============================================
# DEPENDENCIES
# ============================================
node_modules/
package-lock.json

# ============================================
# ENVIRONMENT VARIABLES (SENSITIVE DATA)
# ============================================
.env
.env.local
.env.production
.env.*.local

# ============================================
# GENERATED FILES
# ============================================
backend/certificates/*.pdf
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/qrcodes/.gitkeep
backend/certificates/*
!backend/certificates/.gitkeep

# ============================================
# OS FILES
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# IDE / EDITOR FILES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*

# ============================================
# BUILD OUTPUT
# ============================================
dist/
build/
